<?xml version="1.0" encoding="utf-8"?>
<!-- The main box holding everything together on the splash screen. Added a nice warm cream background color to set the vibe right away. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF2EB"
    tools:context=".SplashActivity">

    <!-- This holds the text logo graphic. It stretches across the whole screen. It starts completely invisible because the code will fade it in later. -->
    <ImageView
        android:id="@+id/ivSplashText"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/splash_text_image"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- The center candle graphic! Pinning it exactly to the middle of the screen. Just like the text, it starts off totally invisible. -->
    <ImageView
        android:id="@+id/ivSplashCandle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/splash_candle"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>