<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_instruction_modal">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_instruction_title"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="60dp"
                android:background="@drawable/bg_instruction_title"
                android:fontFamily="monospace"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Instruction"
                android:textColor="#FFFFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_instruction_intro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_instruction_title"
                android:layout_marginTop="50dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="&quot;Ready to make waves?\nDive in by adding your daily tasks and habits. Set your schedule, turn on reminders, and watch your productivity flow!&quot;"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/tv_instruction_steps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_instruction_intro"
                android:layout_marginTop="40dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="40dp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="6dp"
                android:text="How to use Tidely:\n\n1. Add: Create a new habit or to-do list.\n2. Set: Choose your daily goals and reminders.\n3. Do: Check off tasks to grow your monthly streak!"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp" />

        </RelativeLayout>

    </ScrollView>

    <ImageView
        android:id="@+id/btn_close_instruction"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="34dp"
        android:layout_marginTop="39dp"
        android:src="@drawable/ic_close" />

</RelativeLayout>