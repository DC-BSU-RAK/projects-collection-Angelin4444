<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/bubbly_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bubbly_animation" />

    <TextView
        android:id="@+id/tv_bubbly_speech"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="81dp"
        android:layout_marginEnd="122dp"
        android:alpha="0"
        android:text="Hello\nMy name is Bubbly !\nWhat is your sea name ?"
        android:textAlignment="center"
        android:textColor="#222222"
        android:textSize="18sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_sea_name"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="120dp"
        android:background="@drawable/bg_rounded_input"
        android:hint="USER NAME"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="#333333"
        android:textColorHint="#999999"
        android:textSize="16sp" />

    <ImageView
        android:id="@+id/btn_next_bubbly"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="50dp"
        android:adjustViewBounds="true"
        android:src="@drawable/btn_next" />

</RelativeLayout>