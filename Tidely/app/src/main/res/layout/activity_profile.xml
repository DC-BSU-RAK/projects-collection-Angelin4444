<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#004E8A">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_profile_curve">

        <ImageView
            android:id="@+id/iv_profile_avatar"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="50dp"
            android:src="@drawable/ic_profile_avatar" />

        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/iv_profile_avatar"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="35dp"
            android:fontFamily="monospace"
            android:text="User Name : "
            android:textColor="#003366"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_user_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_user_name"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="15dp"
            android:fontFamily="monospace"
            android:text="Email : "
            android:textColor="#003366"
            android:textSize="22sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:id="@+id/row_notifications"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_below="@id/tv_user_email"
            android:layout_marginStart="30dp"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/bg_notification_box"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:fontFamily="monospace"
                android:text="Notifications"
                android:textColor="#003366"
                android:textSize="24sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_notifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:checked="true"
                android:scaleX="1.4"
                android:scaleY="1.4"
                app:thumbTint="@color/switch_thumb_blue"
                app:trackTint="@color/switch_track_blue" />
        </RelativeLayout>

        <TextView
            android:id="@+id/btn_logout"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_below="@id/row_notifications"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_pill_dark_blue"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="LOGOUT"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_delete_account"
            android:layout_width="260dp"
            android:layout_height="55dp"
            android:layout_below="@id/btn_logout"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_pill_dark_blue"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="DELETE ACCOUNT"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/bottom_nav_bar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/bg_bottom_nav_rounded"
            android:elevation="6dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/nav_home"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginEnd="90dp"
                android:padding="5dp"
                android:src="@drawable/ic_nav_home" />

            <ImageView
                android:id="@+id/nav_profile"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_home_circle"
                android:padding="15dp"
                android:src="@drawable/ic_nav_profile" />
        </LinearLayout>

    </RelativeLayout>
</RelativeLayout>