<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/auth_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_auth" />

    <ImageView
        android:id="@+id/btn_back_signup"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_marginTop="60dp"
        android:layout_marginStart="15dp"
        android:src="@drawable/ic_back_arrow" />

    <ImageView
        android:id="@+id/title_signup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="120dp"
        android:adjustViewBounds="true"
        android:src="@drawable/title_signup" />

    <LinearLayout
        android:id="@+id/input_container_signup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/title_signup"
        android:layout_centerInParent="true"
        android:layout_marginTop="40dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:orientation="vertical">

        <EditText
            android:id="@+id/et_name_signup"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_rounded_input"
            android:hint="NAME"
            android:inputType="textPersonName"
            android:layout_marginBottom="15dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/et_email_signup"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_rounded_input"
            android:hint="EMAIL"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="15dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/et_password_signup"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_rounded_input"
            android:hint="PASSWORD"
            android:inputType="textPassword"
            android:layout_marginBottom="15dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/et_confirm_password_signup"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_rounded_input"
            android:hint="CONFIRM PASSWORD"
            android:inputType="textPassword"
            android:layout_marginBottom="20dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:textSize="16sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_or_signup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/input_container_signup"
        android:layout_centerHorizontal="true"
        android:text="OR"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/social_icons_signup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_or_signup"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="15dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ic_google_signup"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginEnd="15dp"
            android:src="@drawable/ic_google" />

        <ImageView
            android:id="@+id/ic_gmail_signup"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginEnd="15dp"
            android:src="@drawable/ic_gmail" />

        <ImageView
            android:id="@+id/ic_facebook_signup"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_facebook" />

    </LinearLayout>

    <ImageView
        android:id="@+id/btn_lets_go_signup"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/social_icons_signup"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="25dp"
        android:adjustViewBounds="true"
        android:src="@drawable/btn_lets_go" />

</RelativeLayout>