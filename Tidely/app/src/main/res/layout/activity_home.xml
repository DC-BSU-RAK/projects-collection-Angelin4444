<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFC6E4F6">

    <TextView
        android:id="@+id/tv_home_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:text="TODAY"
        android:textColor="#FF004E8A"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/btn_instruction_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="30dp"
        android:text="•••"
        android:textColor="#FF222222"
        android:textSize="24sp"
        android:textStyle="bold" />

    <RelativeLayout
        android:id="@+id/rl_calendar_container"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_below="@id/tv_home_title"
        android:layout_marginTop="20dp"
        android:paddingStart="15dp"
        android:paddingEnd="15dp">

        <TextView
            android:id="@+id/btn_calendar_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="&lt;"
            android:textColor="#FF222222"
            android:textSize="24sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_calendar_strip"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toEndOf="@id/btn_calendar_left"
            android:layout_toStartOf="@id/btn_calendar_right"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:clipToPadding="false"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/btn_calendar_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="&gt;"
            android:textColor="#FF222222"
            android:textSize="24sp" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/ll_tabs_container"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/rl_calendar_container"
        android:layout_marginTop="10dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:elevation="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tab_habit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_active"
            android:gravity="center"
            android:text="HABIT"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tab_todo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_inactive"
            android:gravity="center"
            android:text="TO-DO LIST"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/rl_main_task_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/ll_tabs_container"
        android:layout_above="@id/bottom_nav_bar"
        android:layout_marginTop="-15dp"
        android:background="@drawable/bg_main_task_container"
        android:elevation="2dp">

        <LinearLayout
            android:id="@+id/ll_habit_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:orientation="vertical">
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_todo_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="vertical"
            android:visibility="gone">
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_add_new_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:layout_marginBottom="30dp"
            android:layout_marginStart="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="#FF000000"
                android:gravity="center" />
            <TextView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:gravity="center"
                android:text="+"
                android:layout_marginStart="-35dp"
                android:textColor="#FFFFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_add_new_text"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:background="@drawable/bg_tab_active"
                android:fontFamily="monospace"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Add New Habit"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/bottom_nav_bar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_bottom_nav_rounded"
        android:elevation="6dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/nav_home"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="90dp"
            android:background="@drawable/bg_home_circle"
            android:padding="15dp"
            android:src="@drawable/ic_nav_home" />

        <ImageView
            android:id="@+id/nav_profile"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:padding="5dp"
            android:src="@drawable/ic_nav_profile" />
    </LinearLayout>

</RelativeLayout>