<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFC6E4F6"
    tools:ignore="HardcodedText">

    <!-- Huge padding added here so the back button is super easy to click -->
    <TextView
        android:id="@+id/btn_back_edit_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="20dp"
        android:padding="20dp"
        android:text="◀"
        android:textColor="#FF003366"
        android:textSize="32sp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btn_back_edit_time"
        android:background="@drawable/bg_add_habit_container"
        android:paddingTop="30dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingBottom="50dp">

                <TextView
                    android:id="@+id/tv_edit_time_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Edit Time"
                    android:textColor="#FFFFFFFF"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TimePicker
                    android:id="@+id/time_picker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:theme="@style/Theme.AppCompat.Light"
                    android:timePickerMode="spinner" />

                <LinearLayout
                    android:id="@+id/ll_settings_box"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:background="@drawable/bg_edit_time_settings"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Repeat"
                            android:textColor="#FF003366"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_repeat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:scaleX="1.2"
                            android:scaleY="1.2"
                            app:thumbTint="@color/switch_thumb_blue"
                            app:trackTint="@color/switch_track_blue" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="Sound"
                            android:textColor="#FF003366"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_sound"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:scaleX="1.2"
                            android:scaleY="1.2"
                            app:thumbTint="@color/switch_thumb_blue"
                            app:trackTint="@color/switch_track_blue" />
                    </RelativeLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_save_time"
                    android:layout_width="160dp"
                    android:layout_height="50dp"
                    android:layout_marginTop="30dp"
                    android:background="@drawable/bg_habit_label_pill"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="Save"
                    android:textColor="#FFFFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- This is the empty box where the saved alarms will spawn! -->
                <LinearLayout
                    android:id="@+id/ll_saved_times_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>
    </RelativeLayout>
</RelativeLayout>